<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.bottomnavigation.BottomNavigationView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:background="@drawable/bg_bottom_nav"
    android:paddingHorizontal="6dp"
    android:paddingTop="4dp"
    android:paddingBottom="6dp"
    app:elevation="10dp"
    app:itemIconSize="22dp"
    app:itemIconTint="@color/bottom_nav_item_color"
    app:itemRippleColor="@color/primaryContainer"
    app:itemTextAppearanceActive="@style/TextAppearance.Gestion.BottomNav.Active"
    app:itemTextAppearanceInactive="@style/TextAppearance.Gestion.BottomNav.Inactive"
    app:itemTextColor="@color/bottom_nav_item_color"
    app:labelVisibilityMode="labeled"
    app:menu="@menu/menu_primary_bottom_nav" />
