<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StudentManagementMobile"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.student.StudentFeatureListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.common.AcademicStatisticsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.teacher.TeacherFeatureListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.teacher.TeacherModuleWorkspaceActivity"
            android:exported="false" />
        <activity
            android:name=".ui.teacher.TeacherAssignmentSubmissionsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.teacher.TeacherCreateCourseActivity"
            android:exported="false" />
        <activity
            android:name=".ui.teacher.TeacherCreateAnnouncementActivity"
            android:exported="false" />
        <activity
            android:name=".ui.teacher.TeacherCreateAssignmentActivity"
            android:exported="false" />
        <activity
            android:name=".ui.home.StudentHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.home.AdminFeatureListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.home.ChefFeatureListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.home.TeacherHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.home.AdminHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.home.ChefHomeActivity"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
