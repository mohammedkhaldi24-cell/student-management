<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.StudentManagementMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorPrimaryContainer">@color/primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/onPrimaryContainer</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/primaryDark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Widget.Gestion.PrimaryButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Gestion.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/outline</item>
    </style>

    <style name="Widget.Gestion.DashboardAction" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">62dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">15sp</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="iconTint">@color/primary</item>
        <item name="strokeColor">@color/outline</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
    </style>

    <style name="Widget.Gestion.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/textSecondary</item>
        <item name="startIconTint">@color/primary</item>
        <item name="endIconTint">@color/primary</item>
    </style>

    <style name="Widget.Gestion.BottomNavItem" parent="Widget.Material3.Button.TextButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">11sp</item>
        <item name="iconGravity">top</item>
        <item name="iconPadding">1dp</item>
        <item name="iconSize">20dp</item>
        <item name="iconTint">@color/textSecondary</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
    </style>

    <style name="TextAppearance.Gestion.BottomNav.Active" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.Gestion.BottomNav.Inactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
